	public static function getModuleInfo()
	{
		return [
			'title' => 'MillcoTasks',
			'summary' => 'Card board.',
			'version' => 6,
			'autoload' => true,
			'singular' => true,
			'permanent' => false,
			'permission' => 'millco-tasks',
			'icon' => 'check-square-o',
			'requires' => [
				'PHP>=8.0.0',
				'ProcessWire>=3.0.16',
			],
			'installs' => ['ProcessMillcoTasks']
		];
	}

	// Add config fields.
